{
  "name": "pendulum-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <27"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  },
  "scripts": {
    "check": "node scripts/check-static-assets.mjs && node scripts/bundle-hero.mjs --check",
    "audit": "npm audit --audit-level=high",
    "build:ko": "node scripts/build-ko-page.mjs",
    "assets:icons": "node scripts/generate-icons.mjs",
    "assets:fonts": "python scripts/subset-pretendard.py",
    "assets:og-card": "node scripts/generate-og-card.mjs",
    "build:hero": "node scripts/bundle-hero.mjs",
    "sync:changelog": "node scripts/sync-changelog-highlights.mjs",
    "sync:copy": "node scripts/sync-copy-counts.mjs",
    "lighthouse": "node scripts/run-lighthouse.mjs",
    "lighthouse:lhci": "lhci autorun",
    "test": "playwright test",
    "smoke": "playwright test tests/landing-smoke.spec.ts --project=chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.60.0",
    "esbuild": "^0.28.1",
    "gsap": "^3.15.0",
    "pretendard": "^1.3.9",
    "three": "^0.185.1",
    "wrangler": "^4.112.0"
  }
}
